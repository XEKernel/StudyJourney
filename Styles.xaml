<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ══════════════════════════════════════════════════════
         自定义控件样式（全局）
         CheckBox · RadioButton · Slider · ScrollBar · TabItem
         ══════════════════════════════════════════════════════ -->

    <!-- ──────────────────────────────────────────────
         CheckBox — 滑动开关（Toggle Switch）
         ────────────────────────────────────────────── -->
    <Style TargetType="CheckBox">
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Margin" Value="0,5,0,7"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="#CCE0E0F0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 开关背景轨道 -->
                        <Border x:Name="SwitchTrack"
                                Grid.Column="0"
                                Width="40" Height="22"
                                CornerRadius="11"
                                Background="#22FFFFFF"
                                BorderBrush="#30FFFFFF"
                                BorderThickness="1"
                                Margin="0,0,8,0"/>

                        <!-- 滑块圆钮 -->
                        <Border x:Name="SwitchThumb"
                                Grid.Column="0"
                                Width="18" Height="18"
                                CornerRadius="9"
                                Background="#FFFFFFFF"
                                HorizontalAlignment="Left"
                                Margin="2,0,0,0">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="0.5" BlurRadius="3" Opacity="0.3"/>
                            </Border.Effect>
                        </Border>

                        <!-- 文字标签 -->
                        <ContentPresenter Grid.Column="1"
                                          Content="{TemplateBinding Content}"
                                          VerticalAlignment="Center"
                                          Margin="2,0,0,0"
                                          RecognizesAccessKey="True"/>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <!-- 选中态：轨道变为强调色，滑块滑到右侧 -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="SwitchTrack" Property="Background" Value="#446688CC"/>
                            <Setter TargetName="SwitchTrack" Property="BorderBrush" Value="#FF6688CC"/>
                            <Setter TargetName="SwitchThumb" Property="Margin" Value="20,0,0,0"/>
                            <Setter TargetName="SwitchThumb" Property="Background" Value="#FFFFFFFF"/>
                        </Trigger>

                        <!-- 悬停时轨道微亮 -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="IsChecked" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="SwitchTrack" Property="Background" Value="#33FFFFFF"/>
                        </MultiTrigger>

                        <!-- 悬停 + 选中 -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="IsChecked" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="SwitchTrack" Property="Background" Value="#556688CC"/>
                        </MultiTrigger>

                        <!-- 禁用态 -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <!-- ──────────────────────────────────────────────
         RadioButton — 暗色主题自定义单选圆圈（基础版）
         动画版见 SettingWindow AnimatedRadioStyle
         ────────────────────────────────────────────── -->
    <Style TargetType="RadioButton">
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Margin" Value="0,3,12,3"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="#CCE0E0F0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Grid Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 外圈 -->
                        <Border x:Name="RadioOuter"
                                Grid.Column="0"
                                Width="18" Height="18"
                                CornerRadius="9"
                                Background="#22FFFFFF"
                                BorderBrush="#44FFFFFF"
                                BorderThickness="1.5"
                                Margin="0,0,8,0"
                                SnapsToDevicePixels="True">
                            <!-- 内点 -->
                            <Ellipse x:Name="RadioDot"
                                     Width="8" Height="8"
                                     Fill="#FF6688CC"
                                     Opacity="0"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"/>
                        </Border>

                        <ContentPresenter Grid.Column="1"
                                          Content="{TemplateBinding Content}"
                                          VerticalAlignment="Center"
                                          Margin="2,0,0,0"
                                          RecognizesAccessKey="True"/>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="RadioDot" Property="Opacity" Value="1"/>
                            <Setter TargetName="RadioOuter" Property="BorderBrush" Value="#FF6688CC"/>
                            <Setter TargetName="RadioOuter" Property="Background" Value="#186688CC"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="IsChecked" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="RadioOuter" Property="Background" Value="#33FFFFFF"/>
                            <Setter TargetName="RadioOuter" Property="BorderBrush" Value="#66FFFFFF"/>
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="IsChecked" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="RadioOuter" Property="Background" Value="#226688CC"/>
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <!-- ──────────────────────────────────────────────
         Slider — 暗色圆形拇指 + 渐变轨道
         ────────────────────────────────────────────── -->
    <Style TargetType="Slider">
        <Setter Property="Foreground" Value="#886688CC"/>
        <Setter Property="Background" Value="#22FFFFFF"/>
        <Setter Property="Margin" Value="0,3,0,2"/>
        <Setter Property="IsSnapToTickEnabled" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid Height="20">
                        <!-- 轨道背景（未填充部分） -->
                        <Border Height="4"
                                Background="{TemplateBinding Background}"
                                CornerRadius="2"
                                Margin="8,0"/>
                        <!-- 轨道已填充部分 -->
                        <Border x:Name="TrackFill"
                                Height="4"
                                Background="{TemplateBinding Foreground}"
                                CornerRadius="2"
                                HorizontalAlignment="Left"
                                Margin="8,0"/>

                        <!-- 拇指 Track（透明命中区） -->
                        <Track x:Name="PART_Track">
                            <Track.Thumb>
                                <Thumb x:Name="Thumb"
                                       Width="18" Height="18"
                                       Cursor="Hand">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Grid>
                                                <!-- 外圈发光 -->
                                                <Ellipse x:Name="ThumbOuter"
                                                         Width="18" Height="18"
                                                         Fill="#FFFFFFFF"
                                                         Opacity="0.05"/>
                                                <!-- 主体圆 -->
                                                <Ellipse x:Name="ThumbCore"
                                                         Width="14" Height="14"
                                                         Fill="#FF6688CC">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect ShadowDepth="1" BlurRadius="4" Opacity="0.4"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ThumbCore" Property="Fill" Value="#FF8899DD"/>
                                                    <Setter TargetName="ThumbCore" Property="Width" Value="16"/>
                                                    <Setter TargetName="ThumbCore" Property="Height" Value="16"/>
                                                </Trigger>
                                                <Trigger Property="IsDragging" Value="True">
                                                    <Setter TargetName="ThumbCore" Property="Fill" Value="#FFAABBEE"/>
                                                    <Setter TargetName="ThumbCore" Property="Width" Value="18"/>
                                                    <Setter TargetName="ThumbCore" Property="Height" Value="18"/>
                                                    <Setter TargetName="ThumbOuter" Property="Opacity" Value="0.15"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <!-- ──────────────────────────────────────────────
         ComboBox — 暗色下拉选择框
         ────────────────────────────────────────────── -->
    <Style TargetType="ComboBox">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="#FFFFFFFF"/>
        <Setter Property="Margin" Value="0,0,0,6"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton Name="ToggleButton"
                                      Background="#22FFFFFF"
                                      BorderBrush="#30FFFFFF"
                                      BorderThickness="1"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      ClickMode="Press"
                                      SnapsToDevicePixels="True">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Name="Border"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="6"
                                            SnapsToDevicePixels="True">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="22"/>
                                            </Grid.ColumnDefinitions>
                                            <ContentPresenter Grid.Column="0"
                                                              Margin="8,5,0,5"
                                                              HorizontalAlignment="Left"
                                                              VerticalAlignment="Center"
                                                              IsHitTestVisible="False"/>
                                            <Path Grid.Column="1"
                                                  Data="M0,0 L4,4 L8,0"
                                                  Stroke="#AAFFFFFF"
                                                  StrokeThickness="1.5"
                                                  Fill="Transparent"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Stretch="None"
                                                  SnapsToDevicePixels="True"/>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#33FFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <ContentPresenter Name="ContentSite"
                                          Margin="8,5,24,5"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Center"
                                          IsHitTestVisible="False"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"/>
                        <Popup Name="Popup"
                               Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Fade">
                            <Border Name="DropDownBorder"
                                    Background="#FF222240"
                                    BorderBrush="#40FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                    MinWidth="{TemplateBinding ActualWidth}"
                                    SnapsToDevicePixels="True"
                                    Margin="0,2,0,0">
                                <ScrollViewer SnapsToDevicePixels="True">
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#FFE0E0F0"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border Name="ItemBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="4"
                            Margin="3,1"
                            SnapsToDevicePixels="True">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="#FF334466"/>
                            <Setter Property="Foreground" Value="#FFFFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="#FF2A2A50"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ──────────────────────────────────────────────
         ScrollBar — 细窄暗色滚动条（拇指长度随内容自适应）
         ────────────────────────────────────────────── -->
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid x:Name="Root">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"/>
                        <Track x:Name="PART_Track"
                               IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb x:Name="Thumb"
                                       Cursor="Hand"
                                       Opacity="0.3">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border x:Name="ThumbBorder"
                                                    Background="#88FFFFFF"
                                                    CornerRadius="4"
                                                    Margin="1,2,1,2"/>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ThumbBorder" Property="Background" Value="#CCFFFFFF"/>
                                                </Trigger>
                                                <Trigger Property="IsDragging" Value="True">
                                                    <Setter TargetName="ThumbBorder" Property="Background" Value="#FFFFFFFF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton x:Name="PageUp"
                                              Command="ScrollBar.PageUpCommand"
                                              Opacity="0"
                                              Focusable="False"/>
                            </Track.IncreaseRepeatButton>
                            <Track.DecreaseRepeatButton>
                                <RepeatButton x:Name="PageDown"
                                              Command="ScrollBar.PageDownCommand"
                                              Opacity="0"
                                              Focusable="False"/>
                            </Track.DecreaseRepeatButton>
                        </Track>

                        <!-- 上下箭头按钮（透明、禁止命中测试，否则会拦截 Thumb 拖拽事件） -->
                        <RepeatButton x:Name="LineUp"
                                      Command="ScrollBar.LineUpCommand"
                                      Opacity="0"
                                      IsHitTestVisible="False"
                                      Focusable="False"/>
                        <RepeatButton x:Name="LineDown"
                                      Command="ScrollBar.LineDownCommand"
                                      Opacity="0"
                                      IsHitTestVisible="False"
                                      Focusable="False"/>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <!-- 鼠标悬停时拇指更亮、更宽 -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Thumb" Property="Opacity" Value="0.55"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <!-- ══════════════════════════════════════════════════════
         TabItem — 任务栏菜单（圆角胶囊导航标签）
         ══════════════════════════════════════════════════════ -->
    <Style TargetType="TabItem">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Padding" Value="8,0"/>
        <Setter Property="MinHeight" Value="34"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border Name="TabBorder"
                            Background="Transparent"
                            CornerRadius="8,8,0,0"
                            Padding="{TemplateBinding Padding}"
                            MinHeight="{TemplateBinding MinHeight}"
                            Margin="0,0,2,0"
                            SnapsToDevicePixels="True"
                            UseLayoutRounding="True">
                        <ContentPresenter
                            ContentSource="Header"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            TextBlock.Foreground="#88CCCCDD"
                            TextBlock.FontSize="13"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="TabBorder" Property="Background" Value="#28FFFFFF"/>
                            <Setter TargetName="TabBorder" Property="TextBlock.Foreground" Value="#FFFFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="TabBorder" Property="Background" Value="#15FFFFFF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
