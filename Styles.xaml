<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ══════════════════════════════════════════════════════
         全局颜色调色板 — 暗色主题
         ══════════════════════════════════════════════════════ -->

    <!-- 背景层级 -->
    <Color x:Key="ThemeBgDarkest">#FF121222</Color>
    <Color x:Key="ThemeBgDark">#FF15152A</Color>
    <Color x:Key="ThemeBgMid">#FF1A1A30</Color>
    <Color x:Key="ThemeBgLight">#FF252545</Color>
    <Color x:Key="ThemeBgSurface">#FF222240</Color>

    <!-- 文字层级 -->
    <Color x:Key="ThemeTextPrimary">#FFFFFFFF</Color>
    <Color x:Key="ThemeTextTitle">#FFE8E8F8</Color>
    <Color x:Key="ThemeTextSecondary">#FFE0E0F0</Color>
    <Color x:Key="ThemeTextMuted">#CCE0E0F0</Color>
    <Color x:Key="ThemeTextDim">#88CCCCDD</Color>
    <Color x:Key="ThemeTextVeryDim">#66CCCCDD</Color>
    <Color x:Key="ThemeTextBody">#AACCDDEE</Color>
    <Color x:Key="ThemeTextLink">#FF6688CC</Color>

    <!-- 强调 / 功能色 -->
    <Color x:Key="ThemeAccent">#FF6688CC</Color>
    <Color x:Key="ThemeAccentLight">#886688CC</Color>
    <Color x:Key="ThemeAccentButton">#336688CC</Color>
    <Color x:Key="ThemeDanger">#FF4444</Color>
    <Color x:Key="ThemeDangerLight">#FFFF8888</Color>
    <Color x:Key="ThemeDangerButton">#22FF6666</Color>

    <!-- 边框 / 分割线 -->
    <Color x:Key="ThemeBorderStrong">#30FFFFFF</Color>
    <Color x:Key="ThemeBorder">#20FFFFFF</Color>
    <Color x:Key="ThemeBorderSubtle">#18FFFFFF</Color>
    <Color x:Key="ThemeBorderVerySubtle">#08FFFFFF</Color>

    <!-- 半透明叠加层 -->
    <Color x:Key="ThemeOverlayHover">#33FFFFFF</Color>
    <Color x:Key="ThemeOverlayPressed">#66FFFFFF</Color>
    <Color x:Key="ThemeOverlayActive">#88FFFFFF</Color>
    <Color x:Key="ThemeOverlaySelected">#28FFFFFF</Color>
    <Color x:Key="ThemeOverlaySubtle">#15FFFFFF</Color>

    <!-- 卡片 / 面板 -->
    <Color x:Key="ThemeCardBg">#1AFFFFFF</Color>
    <Color x:Key="ThemeCardBgLight">#10FFFFFF</Color>
    <Color x:Key="ThemeCardBorder">#18FFFFFF</Color>
    <Color x:Key="ThemeTipBorder">#15FFFFFF</Color>

    <!-- 下拉框专用 -->
    <Color x:Key="ThemeDropdownBg">#FF222240</Color>
    <Color x:Key="ThemeDropdownBorder">#40FFFFFF</Color>
    <Color x:Key="ThemeItemHighlight">#FF334466</Color>
    <Color x:Key="ThemeItemSelected">#FF2A2A50</Color>

    <!-- 进度条 / 主窗口 -->
    <Color x:Key="ThemeProgressBg">#33000000</Color>

    <!-- ══════════════════════════════════════════════════════
         画刷快捷键（可选，方便 XAML 绑定）
         ══════════════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="BrushTextPrimary"   Color="{StaticResource ThemeTextPrimary}"/>
    <SolidColorBrush x:Key="BrushTextSecondary" Color="{StaticResource ThemeTextSecondary}"/>
    <SolidColorBrush x:Key="BrushTextMuted"     Color="{StaticResource ThemeTextMuted}"/>
    <SolidColorBrush x:Key="BrushTextDim"       Color="{StaticResource ThemeTextDim}"/>
    <SolidColorBrush x:Key="BrushTextVeryDim"   Color="{StaticResource ThemeTextVeryDim}"/>
    <SolidColorBrush x:Key="BrushAccent"        Color="{StaticResource ThemeAccent}"/>
    <SolidColorBrush x:Key="BrushDanger"        Color="{StaticResource ThemeDanger}"/>


    <!-- ══════════════════════════════════════════════════════
         隐式控件样式（全局生效）
         ══════════════════════════════════════════════════════ -->

    <!-- ── Button ── -->
    <Style TargetType="Button">
        <Setter Property="Background" Value="#33FFFFFF"/>
        <Setter Property="Foreground" Value="#FFFFFFFF"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="Margin" Value="3"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Name="BtnBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="BtnBorder" Property="Background" Value="#66FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="BtnBorder" Property="Background" Value="#88FFFFFF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── TextBlock ── -->
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="#CCE0E0F0"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <!-- ── TextBox ── -->
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="#1AFFFFFF"/>
        <Setter Property="Foreground" Value="#FFFFFFFF"/>
        <Setter Property="CaretBrush" Value="#FF6688CC"/>
        <Setter Property="BorderBrush" Value="#20FFFFFF"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,5"/>
        <Setter Property="Margin" Value="0,0,0,6"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <!-- ── ComboBox ── -->
    <Style TargetType="ComboBox">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="#FFFFFFFF"/>
        <Setter Property="Margin" Value="0,0,0,6"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton Name="ToggleButton"
                                      Background="#22FFFFFF"
                                      BorderBrush="#30FFFFFF"
                                      BorderThickness="1"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      ClickMode="Press"
                                      SnapsToDevicePixels="True">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Name="Border"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="6"
                                            SnapsToDevicePixels="True">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="22"/>
                                            </Grid.ColumnDefinitions>
                                            <ContentPresenter Grid.Column="0"
                                                              Margin="8,5,0,5"
                                                              HorizontalAlignment="Left"
                                                              VerticalAlignment="Center"
                                                              IsHitTestVisible="False"/>
                                            <Path Grid.Column="1"
                                                  Data="M0,0 L4,4 L8,0"
                                                  Stroke="#AAFFFFFF"
                                                  StrokeThickness="1.5"
                                                  Fill="Transparent"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Stretch="None"
                                                  SnapsToDevicePixels="True"/>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#33FFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <ContentPresenter Name="ContentSite"
                                          Margin="8,5,24,5"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Center"
                                          IsHitTestVisible="False"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"/>
                        <Popup Name="Popup"
                               Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Fade">
                            <Border Name="DropDownBorder"
                                    Background="#FF222240"
                                    BorderBrush="#40FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                    MinWidth="{TemplateBinding ActualWidth}"
                                    SnapsToDevicePixels="True"
                                    Margin="0,2,0,0">
                                <ScrollViewer SnapsToDevicePixels="True">
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── ComboBoxItem ── -->
    <Style TargetType="ComboBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#FFE0E0F0"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border Name="ItemBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="4"
                            Margin="3,1"
                            SnapsToDevicePixels="True">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="#FF334466"/>
                            <Setter Property="Foreground" Value="#FFFFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="#FF2A2A50"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Slider ── -->
    <Style TargetType="Slider">
        <Setter Property="Foreground" Value="#886688CC"/>
        <Setter Property="Margin" Value="0,3,0,2"/>
    </Style>

    <!-- ── CheckBox ── -->
    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="#CCE0E0F0"/>
        <Setter Property="Margin" Value="0,5,0,7"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <!-- ── RadioButton ── -->
    <Style TargetType="RadioButton">
        <Setter Property="Foreground" Value="#CCE0E0F0"/>
        <Setter Property="Margin" Value="0,3,12,3"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <!-- ── TabItem ── -->
    <Style TargetType="TabItem">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Padding" Value="8,0"/>
        <Setter Property="MinHeight" Value="34"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border Name="TabBorder"
                            Background="Transparent"
                            CornerRadius="8,8,0,0"
                            Padding="{TemplateBinding Padding}"
                            MinHeight="{TemplateBinding MinHeight}"
                            Margin="0,0,2,0"
                            SnapsToDevicePixels="True"
                            UseLayoutRounding="True">
                        <ContentPresenter
                            ContentSource="Header"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            TextBlock.Foreground="#88CCCCDD"
                            TextBlock.FontSize="13"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="TabBorder" Property="Background" Value="#28FFFFFF"/>
                            <Setter TargetName="TabBorder" Property="TextBlock.Foreground" Value="#FFFFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="TabBorder" Property="Background" Value="#15FFFFFF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── ProgressBar ── -->
    <Style TargetType="ProgressBar">
        <Setter Property="Background" Value="#33000000"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="Height" Value="10"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Grid MinHeight="{TemplateBinding Height}">
                        <Border x:Name="Track"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5"/>
                        <Border x:Name="Indicator"
                                Background="{TemplateBinding Foreground}"
                                CornerRadius="5"
                                HorizontalAlignment="Left">
                            <Border x:Name="Glow"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="5"
                                    Opacity="0.4">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="6" ShadowDepth="0"
                                                      Color="{Binding Foreground.Color, RelativeSource={RelativeSource TemplatedParent}}"/>
                                </Border.Effect>
                            </Border>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── ScrollViewer ── -->
    <Style TargetType="ScrollViewer">
        <Setter Property="Background" Value="Transparent"/>
    </Style>


    <!-- ══════════════════════════════════════════════════════
         具名样式（x:Key）
         ══════════════════════════════════════════════════════ -->

    <!-- 分组标题 -->
    <Style x:Key="SectionTitle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#FFFFFFFF"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Margin" Value="0,14,0,8"/>
    </Style>

    <!-- 卡片容器 -->
    <Style x:Key="CardPanel" TargetType="Border">
        <Setter Property="Background" Value="#10FFFFFF"/>
        <Setter Property="BorderBrush" Value="#18FFFFFF"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="12"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <!-- 颜色预览块 -->
    <Style x:Key="ColorPreview" TargetType="Rectangle">
        <Setter Property="Width" Value="24"/>
        <Setter Property="Height" Value="24"/>
        <Setter Property="RadiusX" Value="5"/>
        <Setter Property="RadiusY" Value="5"/>
        <Setter Property="Margin" Value="6,0,0,0"/>
        <Setter Property="Stroke" Value="#30FFFFFF"/>
        <Setter Property="StrokeThickness" Value="1"/>
    </Style>

</ResourceDictionary>
