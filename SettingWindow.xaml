                                                    <Style TargetType="ComboBox"
                                                           BasedOn="{StaticResource {x:Type ComboBox}}">
                                                        <Setter Property="FontSize" Value="11"/>
                                                    </Style>
                                                </DataGridComboBoxColumn.EditingElementStyle>
