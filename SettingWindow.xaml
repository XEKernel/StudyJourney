<Window x:Class="GaokaoCountdown.SettingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Height="700"
        Width="780"
        MinHeight="650"
        MinWidth="720"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <!-- ═══════ 颜色常量 ═══════ -->
        <Color x:Key="BgDark">#FF15152A</Color>
        <Color x:Key="BgMid">#FF1E1E3A</Color>
        <Color x:Key="CardBg">#1AFFFFFF</Color>
        <Color x:Key="CardBorder">#20FFFFFF</Color>

        <!-- ═══════ 按钮 ═══════ -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#33FFFFFF"/>
            <Setter Property="Foreground" Value="#FFFFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Name="BtnBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#66FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#88FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════ 标签文字 ═══════ -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCE0E0F0"/>
            <Setter Property="Margin" Value="0,6,0,2"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- ═══════ 输入框 ═══════ -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1AFFFFFF"/>
            <Setter Property="Foreground" Value="#FFFFFFFF"/>
            <Setter Property="CaretBrush" Value="#FF6688CC"/>
            <Setter Property="BorderBrush" Value="#20FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- ═══════ 下拉框（完整模板 — 暗色 Popup 解决文字不可见）═══════ -->
        <Style TargetType="ComboBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#FFFFFFFF"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Name="ToggleButton"
                                          Background="#22FFFFFF"
                                          BorderBrush="#30FFFFFF"
                                          BorderThickness="1"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"
                                          SnapsToDevicePixels="True">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Name="Border"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6"
                                                SnapsToDevicePixels="True">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition/>
                                                    <ColumnDefinition Width="22"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"
                                                                  Margin="8,5,0,5"
                                                                  HorizontalAlignment="Left"
                                                                  VerticalAlignment="Center"
                                                                  IsHitTestVisible="False"/>
                                                <Path Grid.Column="1"
                                                      Data="M0,0 L4,4 L8,0"
                                                      Stroke="#AAFFFFFF"
                                                      StrokeThickness="1.5"
                                                      Fill="Transparent"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Stretch="None"
                                                      SnapsToDevicePixels="True"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#33FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Name="ContentSite"
                                              Margin="8,5,24,5"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"/>
                            <Popup Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border Name="DropDownBorder"
                                        Background="#FF222240"
                                        BorderBrush="#40FFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        SnapsToDevicePixels="True"
                                        Margin="0,2,0,0">
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════ 下拉列表项 ═══════ -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFE0E0F0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="4"
                                Margin="3,1"
                                SnapsToDevicePixels="True">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#FF334466"/>
                                <Setter Property="Foreground" Value="#FFFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#FF2A2A50"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

                <!-- ═════ TabItem — 圆角胶囊（固定高度防位移） ═════ -->
        <Style TargetType="TabItem">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="TabBorder"
                                Background="Transparent"
                                CornerRadius="8,8,0,0"
                                Padding="{TemplateBinding Padding}"
                                MinHeight="{TemplateBinding MinHeight}"
                                Margin="0,0,2,0"
                                SnapsToDevicePixels="True"
                                UseLayoutRounding="True">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <ContentPresenter
                                    Grid.Row="0"
                                    ContentSource="Header"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    TextBlock.Foreground="#88CCCCDD"
                                    TextBlock.FontSize="13"/>
                                <!-- 底部指示条 -->
                                <Rectangle x:Name="Indicator"
                                           Grid.Row="1"
                                           Height="3"
                                           Margin="6,0,6,0"
                                           Fill="#FF6688CC"
                                           RadiusX="1.5"
                                           RadiusY="1.5"
                                           Opacity="0">
                                    <Rectangle.RenderTransform>
                                        <ScaleTransform ScaleX="0" ScaleY="1"/>
                                    </Rectangle.RenderTransform>
                                </Rectangle>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="Indicator"
                                                Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                From="0" To="1"
                                                Duration="0:0:0.35">
                                                <DoubleAnimation.EasingFunction>
                                                    <PowerEase Power="3" EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation
                                                Storyboard.TargetName="Indicator"
                                                Storyboard.TargetProperty="Opacity"
                                                From="0" To="1"
                                                Duration="0:0:0.25"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="Indicator"
                                                Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                From="1" To="0"
                                                Duration="0:0:0.25">
                                                <DoubleAnimation.EasingFunction>
                                                    <PowerEase Power="3" EasingMode="EaseIn"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation
                                                Storyboard.TargetName="Indicator"
                                                Storyboard.TargetProperty="Opacity"
                                                From="1" To="0"
                                                Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                                <Setter TargetName="TabBorder" Property="Background" Value="#28FFFFFF"/>
                                <Setter TargetName="TabBorder" Property="TextBlock.Foreground" Value="#FFFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#15FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════ 分组标题 ═══════ -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFFFFFFF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,14,0,8"/>
        </Style>

        <!-- ═══════ 卡片容器 ═══════ -->
        <Style x:Key="CardPanel" TargetType="Border">
            <Setter Property="Background" Value="#10FFFFFF"/>
            <Setter Property="BorderBrush" Value="#18FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- ═══════ 颜色预览 ═══════ -->
        <Style x:Key="ColorPreview" TargetType="Rectangle">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="RadiusX" Value="5"/>
            <Setter Property="RadiusY" Value="5"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Stroke" Value="#30FFFFFF"/>
            <Setter Property="StrokeThickness" Value="1"/>
        </Style>

        <!-- ═══════════════════════════════════════════════════
             动画版控件样式（由「动画」设置 Tab 控制开关）
             ═══════════════════════════════════════════════════ -->

        <!-- RadioButton 动画版：内点弹入弹出 -->
        <Style x:Key="AnimatedRadioStyle" TargetType="RadioButton" BasedOn="{x:Null}">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,3,12,3"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#CCE0E0F0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="RadioOuter"
                                    Grid.Column="0"
                                    Width="18" Height="18"
                                    CornerRadius="9"
                                    Background="#22FFFFFF"
                                    BorderBrush="#44FFFFFF"
                                    BorderThickness="1.5"
                                    Margin="0,0,8,0"
                                    SnapsToDevicePixels="True">
                                <Ellipse x:Name="RadioDot"
                                         Width="8" Height="8"
                                         Fill="#FF6688CC"
                                         Opacity="0"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                            </Border>
                            <ContentPresenter Grid.Column="1"
                                              Content="{TemplateBinding Content}"
                                              VerticalAlignment="Center"
                                              Margin="2,0,0,0"
                                              RecognizesAccessKey="True"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="RadioDot" Property="Opacity" Value="1"/>
                                <Setter TargetName="RadioOuter" Property="BorderBrush" Value="#FF6688CC"/>
                                <Setter TargetName="RadioOuter" Property="Background" Value="#186688CC"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="RadioOuter" Property="Background" Value="#33FFFFFF"/>
                                <Setter TargetName="RadioOuter" Property="BorderBrush" Value="#66FFFFFF"/>
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="RadioOuter" Property="Background" Value="#226688CC"/>
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>

                            <!-- ═══ 选中动画 ═══ -->
                            <EventTrigger RoutedEvent="RadioButton.Checked">
                                <BeginStoryboard>
                                    <Storyboard FillBehavior="Stop">
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="RadioDot"
                                                                       Storyboard.TargetProperty="Width">
                                            <EasingDoubleKeyFrame KeyTime="0:0:0"    Value="0"/>
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.22" Value="10.5">
                                                <EasingDoubleKeyFrame.EasingFunction>
                                                    <BackEase EasingMode="EaseOut" Amplitude="0.35"/>
                                                </EasingDoubleKeyFrame.EasingFunction>
                                            </EasingDoubleKeyFrame>
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.38" Value="8"/>
                                        </DoubleAnimationUsingKeyFrames>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="RadioDot"
                                                                       Storyboard.TargetProperty="Height">
                                            <EasingDoubleKeyFrame KeyTime="0:0:0"    Value="0"/>
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.22" Value="10.5">
                                                <EasingDoubleKeyFrame.EasingFunction>
                                                    <BackEase EasingMode="EaseOut" Amplitude="0.35"/>
                                                </EasingDoubleKeyFrame.EasingFunction>
                                            </EasingDoubleKeyFrame>
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.38" Value="8"/>
                                        </DoubleAnimationUsingKeyFrames>
                                        <DoubleAnimation Storyboard.TargetName="RadioDot"
                                                         Storyboard.TargetProperty="Opacity"
                                                         From="0" To="1" Duration="0:0:0.18"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>

                            <!-- ═══ 取消选中动画 ═══ -->
                            <EventTrigger RoutedEvent="RadioButton.Unchecked">
                                <BeginStoryboard>
                                    <Storyboard FillBehavior="Stop">
                                        <DoubleAnimation Storyboard.TargetName="RadioDot"
                                                         Storyboard.TargetProperty="Width"
                                                         To="0" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="RadioDot"
                                                         Storyboard.TargetProperty="Height"
                                                         To="0" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="RadioDot"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.12"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CheckBox 动画版：滑动开关带平滑动效 -->
        <Style x:Key="AnimatedCheckStyle" TargetType="CheckBox" BasedOn="{x:Null}">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,5,0,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#CCE0E0F0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="SwitchTrack"
                                    Grid.Column="0"
                                    Width="40" Height="22"
                                    CornerRadius="11"
                                    Background="#22FFFFFF"
                                    BorderBrush="#30FFFFFF"
                                    BorderThickness="1"
                                    Margin="0,0,8,0"/>
                            <Border x:Name="SwitchThumb"
                                    Grid.Column="0"
                                    Width="18" Height="18"
                                    CornerRadius="9"
                                    Background="#FFFFFFFF"
                                    HorizontalAlignment="Left"
                                    Margin="2,0,0,0">
                                <Border.Effect>
                                    <DropShadowEffect ShadowDepth="0.5" BlurRadius="3" Opacity="0.3"/>
                                </Border.Effect>
                            </Border>
                            <ContentPresenter Grid.Column="1"
                                              Content="{TemplateBinding Content}"
                                              VerticalAlignment="Center"
                                              Margin="2,0,0,0"
                                              RecognizesAccessKey="True"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchTrack" Property="Background" Value="#446688CC"/>
                                <Setter TargetName="SwitchTrack" Property="BorderBrush" Value="#FF6688CC"/>
                                <Setter TargetName="SwitchThumb" Property="Margin" Value="20,0,0,0"/>
                                <Setter TargetName="SwitchThumb" Property="Background" Value="#FFFFFFFF"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="SwitchTrack" Property="Background" Value="#33FFFFFF"/>
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="SwitchTrack" Property="Background" Value="#556688CC"/>
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>

                            <!-- ═══ 选中：滑块右滑 ═══ -->
                            <EventTrigger RoutedEvent="CheckBox.Checked">
                                <BeginStoryboard>
                                    <Storyboard FillBehavior="Stop">
                                        <ThicknessAnimationUsingKeyFrames Storyboard.TargetName="SwitchThumb"
                                                                          Storyboard.TargetProperty="Margin">
                                            <EasingThicknessKeyFrame KeyTime="0:0:0" Value="2,0,0,0"/>
                                            <EasingThicknessKeyFrame KeyTime="0:0:0.25" Value="20,0,0,0">
                                                <EasingThicknessKeyFrame.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </EasingThicknessKeyFrame.EasingFunction>
                                            </EasingThicknessKeyFrame>
                                        </ThicknessAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>

                            <!-- ═══ 取消选中：滑块左滑 ═══ -->
                            <EventTrigger RoutedEvent="CheckBox.Unchecked">
                                <BeginStoryboard>
                                    <Storyboard FillBehavior="Stop">
                                        <ThicknessAnimationUsingKeyFrames Storyboard.TargetName="SwitchThumb"
                                                                          Storyboard.TargetProperty="Margin">
                                            <EasingThicknessKeyFrame KeyTime="0:0:0" Value="20,0,0,0"/>
                                            <EasingThicknessKeyFrame KeyTime="0:0:0.2" Value="2,0,0,0">
                                                <EasingThicknessKeyFrame.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </EasingThicknessKeyFrame.EasingFunction>
                                            </EasingThicknessKeyFrame>
                                        </ThicknessAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- ══════ DataGrid 暗色主题样式 ══════ -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#AA0D0D1A"/>
            <Setter Property="Foreground" Value="#FFCCCCDD"/>
            <Setter Property="BorderBrush" Value="#30FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="#AA1A1A2E"/>
            <Setter Property="AlternatingRowBackground" Value="#BB13132A"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#20FFFFFF"/>
            <Setter Property="VerticalGridLinesBrush" Value="#15FFFFFF"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="RowHeight" Value="28"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#CC0D0D1A"/>
            <Setter Property="Foreground" Value="#FFFFFFFF"/>
            <Setter Property="BorderBrush" Value="#30FFFFFF"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="6,4,6,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#10FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#662E86C1"/>
                    <Setter Property="BorderBrush" Value="#FF5B9BD5"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#332E86C1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,0,4,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter VerticalAlignment="Center"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#FFFFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridRowHeader">
            <Setter Property="Background" Value="#CC0D0D1A"/>
            <Setter Property="BorderBrush" Value="#30FFFFFF"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="Width" Value="0"/>
        </Style>

    </Window.Resources>

    <!-- ══════════════════════════════════════════════════════
         窗口主体结构
         ══════════════════════════════════════════════════════ -->
    <Grid Name="MainGrid">
        <!-- ── 渐变背景 ── -->
        <Rectangle RadiusX="14" RadiusY="14">
            <Rectangle.Fill>
                <RadialGradientBrush RadiusX="1.2" RadiusY="1.2" Center="0.5,0.3">
                    <GradientStop Color="#FF252545" Offset="0"/>
                    <GradientStop Color="#FF1A1A30" Offset="0.5"/>
                    <GradientStop Color="#FF121222" Offset="1"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- ── 外发光边框 ── -->
        <Rectangle RadiusX="14" RadiusY="14" Stroke="#18FFFFFF" StrokeThickness="1.5"/>
        <Rectangle RadiusX="14" RadiusY="14" Stroke="#08FFFFFF" StrokeThickness="3"
                   Margin="-1"/>

        <!-- ── 主内容区 ── -->
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="48"/>
            </Grid.RowDefinitions>

            <!-- ══════ 标题栏 ══════ -->
            <Border Grid.Row="0" Background="#08FFFFFF" CornerRadius="14,14,0,0">
                <Grid Margin="16,0,10,0">
                    <TextBlock Text="设置"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="#FFE8E8F8"
                               VerticalAlignment="Center"/>
                    <Button Content="&#x2715;" Click="CloseButton_Click"
                            Width="28" Height="28" Margin="0" Padding="0"
                            HorizontalAlignment="Right"
                            Background="#20FF4444" FontSize="12"
                            Foreground="#FFFF8888"/>
                </Grid>
            </Border>

            <!-- ══════ TabControl（仅头部）+ 内容面板 ══════ -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Tab 头部（仅 Header，无内容） -->
                <TabControl Grid.Row="0" Background="Transparent" BorderThickness="0"
                            Name="MainTabControl"
                            SelectionChanged="MainTabControl_SelectionChanged"
                            TabStripPlacement="Top">
                    <TabControl.Template>
                        <ControlTemplate TargetType="TabControl">
                            <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                         VerticalScrollBarVisibility="Disabled"
                                         Background="Transparent"
                                         CanContentScroll="False"
                                         Padding="0">
                                <StackPanel x:Name="HeaderPanel"
                                            Orientation="Horizontal"
                                            IsItemsHost="True"
                                            Background="Transparent"
                                            KeyboardNavigation.TabIndex="1"/>
                            </ScrollViewer>
                        </ControlTemplate>
                    </TabControl.Template>

                    <TabControl.Resources>
                    </TabControl.Resources>

                    <TabItem Header="&#x1F3A8; 外观" />
                    <TabItem Header="&#x1F4D0; 位置" />
                    <TabItem Header="&#x1F441; 显示" />
                    <TabItem Header="&#x270F; 文本" />
                    <TabItem Header="&#x1F4C5; 日期" />
                    <TabItem Header="&#x2728; 动画" />
                    <TabItem Header="&#x1F50C; API" />
                    <TabItem Header="&#x1F4CB; 课表" />
                    <TabItem Header="&#x1F4DD; 考试" />
                    <TabItem Header="&#x2139; 关于" />
                </TabControl>

                <!-- 内容面板（手动切换，支持出入场动画） -->
                <Grid Grid.Row="1" Margin="8,-2,8,0" ClipToBounds="True" x:Name="ContentHost">
                    <!-- ═══ TAB 0：外观 ═══ -->
                    <ScrollViewer x:Name="ContentAppearance" VerticalScrollBarVisibility="Auto" CanContentScroll="False"
                                  Visibility="Visible">
                        <StackPanel Margin="6,8,6,12">
                            <!-- 字体卡片 -->
                            <Border Style="{StaticResource CardPanel}">
                                <StackPanel>
                                    <TextBlock Text="字体与字号" Style="{StaticResource SectionTitle}" Margin="0,0,0,10"/>
                                    <ComboBox Name="FontFamilyComboBox"
                                              SelectionChanged="FontFamilyComboBox_SelectionChanged"/>
                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="48"/>
                                        </Grid.ColumnDefinitions>
                                        <Slider Grid.Column="0" Name="FontSizeSlider"
                                                Minimum="16" Maximum="72" Value="40"
                                                TickFrequency="1" IsSnapToTickEnabled="True"
                                                ValueChanged="FontSizeSlider_ValueChanged"/>
                                        <TextBlock Grid.Column="1" Name="FontSizeText" Text="40"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Margin="8,0,0,0" FontSize="14"
                                                   Foreground="#CCE0E0F0"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- 透明度卡片 -->
                            <Border Style="{StaticResource CardPanel}">
                                <StackPanel>
                                    <TextBlock Text="窗口透明度" Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="56"/>
                                        </Grid.ColumnDefinitions>
                                        <Slider Grid.Column="0" Name="OpacitySlider"
                                                Minimum="0.1" Maximum="1.0" Value="1.0"
                                                TickFrequency="0.05"
                                                ValueChanged="OpacitySlider_ValueChanged"/>
                                        <TextBlock Grid.Column="1" Name="OpacityText" Text="100%"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Margin="8,0,0,0" FontSize="14"
                                                   Foreground="#CCE0E0F0"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- 颜色卡片 -->
                            <Border Style="{StaticResource CardPanel}">
                                <StackPanel>
                                    <TextBlock Text="配色方案" Style="{StaticResource SectionTitle}" Margin="0,0,0,10"/>

                                    <TextBlock Text="数字颜色（天 / 时 / 分 / 秒）" Margin="0,4,0,2"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBox Name="NumberColorBox" Width="110"/>
                                        <Rectangle Name="NumberColorPreview" Style="{StaticResource ColorPreview}"/>
                                        <Button Content="选择…" Click="SelectNumberColor_Click"
                                                Width="56" Margin="8,0,0,0" FontSize="12"/>
                                    </StackPanel>

                                    <TextBlock Text="文字颜色（标签 / 说明）" Margin="0,8,0,2"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBox Name="TextColorBox" Width="110"/>
                                        <Rectangle Name="TextColorPreview" Style="{StaticResource ColorPreview}"/>
                                        <Button Content="选择…" Click="SelectTextColor_Click"
                                                Width="56" Margin="8,0,0,0" FontSize="12"/>
                                    </StackPanel>

                                    <TextBlock Text="进度条颜色" Margin="0,8,0,2"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBox Name="ProgressBarColorBox" Width="110"/>
                                        <Rectangle Name="ProgressBarColorPreview" Style="{StaticResource ColorPreview}"/>
                                        <Button Content="选择…" Click="SelectProgressBarColor_Click"
                                                Width="56" Margin="8,0,0,0" FontSize="12"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- ═══ TAB 1：位置 ═══ -->
                    <ScrollViewer x:Name="ContentPosition" VerticalScrollBarVisibility="Auto" CanContentScroll="False"
                                  Visibility="Collapsed">
                        <StackPanel Margin="6,8,6,12">

                            <Border Style="{StaticResource CardPanel}">
                                <StackPanel>
                                    <TextBlock Text="屏幕位置预设" Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>
                                    <RadioButton Name="PosTop" GroupName="PositionGroup">顶部</RadioButton>
                                    <RadioButton Name="PosUpperCenter" GroupName="PositionGroup" IsChecked="True">中上（默认）</RadioButton>
                                    <RadioButton Name="PosCenter" GroupName="PositionGroup">居中</RadioButton>
                                    <RadioButton Name="PosLowerCenter" GroupName="PositionGroup">中下</RadioButton>
                                    <RadioButton Name="PosBottom" GroupName="PositionGroup">底部</RadioButton>
                                    <RadioButton Name="PosCustom" GroupName="PositionGroup"
                                                 Checked="PosCustom_Checked" Unchecked="PosCustom_Unchecked"
                                                 Margin="0,3,12,0">自定义坐标</RadioButton>

                                    <StackPanel Name="CustomPosPanel" IsEnabled="False" Opacity="0.5"
                                                Margin="12,8,0,0">
                                        <TextBlock Text="X 坐标（像素；-1 = 水平居中）"/>
                                        <TextBox Name="CustomXBox" Text="-1" Width="120"/>
                                        <TextBlock Text="Y 坐标（像素；-1 = 自动）"/>
                                        <TextBox Name="CustomYBox" Text="-1" Width="120"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardPanel}">
                                <StackPanel>
                                    <TextBlock Text="微调" Style="{StaticResource SectionTitle}" Margin="0,0,0,6"/>
                                    <TextBlock Text="垂直偏移像素（负值=上移，正值=下移）" Margin="0,0,0,2"/>
                                    <TextBox Name="OffsetYBox" Text="0" Width="80"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardPanel}">
                                <StackPanel>
                                    <TextBlock Text="窗口层级" Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>
                                    <CheckBox Name="AlwaysOnTopCheck"
                                              Content="始终置顶（覆盖在其他窗口上方）"/>
                                    <TextBlock Text="关闭后窗口位于桌面壁纸上方、其他窗口下方"
                                               FontSize="11" Foreground="#66CCCCDD"
                                               Margin="20,0,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardPanel}">
                                <StackPanel>
                                    <TextBlock Text="&#x1F680;  系统" Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>
                                    <CheckBox Name="AutoStartCheck"
                                              Content="开机自动启动"
                                              Checked="AutoStartCheck_Changed"
                                              Unchecked="AutoStartCheck_Changed"/>
                                    <TextBlock FontSize="11" Foreground="#66CCCCDD"
                                               Margin="20,0,0,8" TextWrapping="Wrap">
                                        <Run Text="写入当前用户注册表 Run 键，无需管理员权限。"/>
                                        <LineBreak/>
                                        <Run Text="若程序路径发生变化（如移动文件夹），请重新勾选一次。"/>
                                    </TextBlock>
                                    <CheckBox Name="HideWhenMaximizedCheck"
                                              Content="其他应用最大化时自动隐藏"
                                              Checked="HideWhenMaximizedCheck_Changed"
                                              Unchecked="HideWhenMaximizedCheck_Changed"/>
                                    <CheckBox x:Name="HideDuringClassCheck"
                                              Content="上课/考试时自动隐藏倒计时窗口"
                                              Margin="0,6,0,0"/>
                                    <TextBlock FontSize="11" Foreground="#66CCCCDD"
                                               Margin="20,0,0,0" TextWrapping="Wrap">
                                        <Run Text="前台窗口最大化时自动隐藏倒计时，恢复时重新显示。"/>
                                        <LineBreak/>
                                        <Run Text="不影响托盘右键显示/隐藏功能。"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- ═══ TAB 2：显示 ═══ -->
                    <ScrollViewer x:Name="ContentDisplay" VerticalScrollBarVisibility="Auto" CanContentScroll="False"
                                  Visibility="Collapsed">
                        <StackPanel Margin="6,8,6,12">

                            <Border Style="{StaticResource CardPanel}">
                                <StackPanel>
                                    <TextBlock Text="可见内容" Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>
                                    <CheckBox Name="ShowEnglishCheck"  Content="显示英文倒计时行"/>
                                    <CheckBox Name="ShowProgressBarCheck" Content="显示进度条"/>
                                    <CheckBox Name="ShowProgressTextCheck" Content="显示进度百分比文字"/>
                                </StackPanel>
                            </Border>

                            <!-- 新增：时间精度卡片 -->
                            <Border Style="{StaticResource CardPanel}">
                                <StackPanel>
                                    <TextBlock Text="时间精度 · 显示哪些单位" Style="{StaticResource SectionTitle}" Margin="0,0,0,4"/>
                                    <TextBlock Text="隐藏某一单位后，该数字与标签均不显示；至少保留一项以防页面空白。"
                                               FontSize="11" Foreground="#66CCCCDD" TextWrapping="Wrap" Margin="0,0,0,10"/>
                                    <CheckBox Name="ShowDaysCheck"    Content="&#x1F4C5;  天（Days）"/>
                                    <CheckBox Name="ShowHoursCheck"   Content="&#x23F0;  小时（Hours）"/>
                                    <CheckBox Name="ShowMinutesCheck" Content="&#x23F1;  分钟（Minutes）"/>
                                    <CheckBox Name="ShowSecondsCheck" Content="&#x231B;  秒（Seconds）"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardPanel}">
                                <StackPanel>
                                    <TextBlock Text="进度百分比精度" Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>
                                    <TextBlock Text="小数位数（0 ～ 10）"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="48"/>
                                        </Grid.ColumnDefinitions>
                                        <Slider Grid.Column="0" Name="DecimalSlider"
                                                Minimum="0" Maximum="10" Value="7"
                                                TickFrequency="1" IsSnapToTickEnabled="True"
                                                ValueChanged="DecimalSlider_ValueChanged"/>
                                        <TextBlock Grid.Column="1" Name="DecimalText" Text="7"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Margin="8,0,0,0" FontSize="14"
                                                   Foreground="#CCE0E0F0"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- ═══ TAB 3：文本 ═══ -->
                    <ScrollViewer x:Name="ContentText" VerticalScrollBarVisibility="Auto" CanContentScroll="False"
                                  Visibility="Collapsed">
                        <StackPanel Margin="6,8,6,12">

                            <Border Style="{StaticResource CardPanel}">
                                <StackPanel>
                                    <TextBlock Text="中文文本" Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>
                                    <TextBlock Text="前缀"/>
                                    <TextBox Name="ChinesePrefixText"/>
                                    <TextBlock Text="天 的后缀"/>
                                    <TextBox Name="ChineseDaysText"/>
                                    <TextBlock Text="小时 的后缀"/>
                                    <TextBox Name="ChineseHoursText"/>
                                    <TextBlock Text="分 的后缀"/>
                                    <TextBox Name="ChineseMinutesText"/>
                                    <TextBlock Text="秒 的后缀"/>
                                    <TextBox Name="ChineseSecondsText"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardPanel}">
                                <StackPanel>
                                    <TextBlock Text="英文文本" Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>
                                    <TextBlock Text="前缀"/>
                                    <TextBox Name="EnglishPrefixText"/>
                                    <TextBlock Text="天（days）后缀"/>
                                    <TextBox Name="EnglishDaysText"/>
                                    <TextBlock Text="小时（hours）后缀"/>
                                    <TextBox Name="EnglishHoursText"/>
                                    <TextBlock Text="分钟（minutes）后缀"/>
                                    <TextBox Name="EnglishMinutesText"/>
                                    <TextBlock Text="秒（seconds）后缀 / 结尾"/>
                                    <TextBox Name="EnglishSecondsText"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- ═══ TAB 4：日期 ═══ -->
                    <ScrollViewer x:Name="ContentDate" VerticalScrollBarVisibility="Auto" CanContentScroll="False"
                                  Visibility="Collapsed">
                        <StackPanel Margin="6,8,6,12">

                            <Border Style="{StaticResource CardPanel}">
                                <StackPanel>
                                    <TextBlock Text="目标考试日期" Style="{StaticResource SectionTitle}" Margin="0,0,0,6"/>
                                    <TextBlock Text="格式：yyyy-MM-dd HH:mm:ss  （例：2027-06-07 09:00:00）"
                                               FontSize="11" Foreground="#66CCCCDD" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                    <TextBox Name="GaokaoDateBox"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardPanel}">
                                <StackPanel>
                                    <TextBlock Text="进度条起算日期" Style="{StaticResource SectionTitle}" Margin="0,0,0,6"/>
                                    <TextBlock Text="格式：yyyy-MM-dd  （例：2024-08-24）"
                                               FontSize="11" Foreground="#66CCCCDD" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                    <TextBox Name="StartDateBox"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#10FFFFFF" CornerRadius="6" Padding="10" Margin="0,2,0,0"
                                    BorderBrush="#15FFFFFF" BorderThickness="1">
                                <TextBlock Foreground="#88CCCCDD" FontSize="11" TextWrapping="Wrap"
                                           Text="进度条显示从「起算日期」到「考试日期」之间已经过去的百分比。修改后点击「应用」立即生效。"/>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- ═══ TAB 5：动画 ═══ -->
                    <ScrollViewer x:Name="ContentAnimation" VerticalScrollBarVisibility="Auto" CanContentScroll="False"
                                  Visibility="Collapsed">
                        <StackPanel Margin="6,8,6,12">

                            <Border Style="{StaticResource CardPanel}">
                                <StackPanel>
                                    <TextBlock Text="主窗口动画" Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>
                                    <CheckBox Name="EnableAnimationsCheck"
                                              Content="启用数字脉冲动画 &amp; 进度条平滑过渡"
                                              Checked="EnableAnimationsCheck_Changed"
                                              Unchecked="EnableAnimationsCheck_Changed"/>
                                    <TextBlock Text="关闭后数字每秒直接更新，进度条直接跳转，性能更节省"
                                               FontSize="11" Foreground="#66CCCCDD"
                                               Margin="20,0,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardPanel}">
                                <StackPanel>
                                    <TextBlock Text="设置窗口动画" Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>
                                    <CheckBox Name="EnableSettingsAnimationsCheck"
                                              Content="启用设置窗口过渡动画"
                                              Checked="EnableSettingsAnimationsCheck_Changed"
                                              Unchecked="EnableSettingsAnimationsCheck_Changed"/>
                                    <TextBlock Text="包括窗口淡入效果、Tab 切换过渡、控件入场动画"
                                               FontSize="11" Foreground="#66CCCCDD"
                                               Margin="20,0,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#10FFFFFF" CornerRadius="6" Padding="10" Margin="0,2,0,0"
                                    BorderBrush="#15FFFFFF" BorderThickness="1">
                                <TextBlock Foreground="#88CCCCDD" FontSize="11" TextWrapping="Wrap"
                                           Text="提示：窗口动画为本次生效，下次打开时重新读取保存的设置。"/>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- ═══ TAB 6：API 功能（每日一言 + 天气） ═══ -->
                    <ScrollViewer x:Name="ContentApi" VerticalScrollBarVisibility="Auto" CanContentScroll="False"
                                  Visibility="Collapsed">
                        <StackPanel Margin="6,8,6,12">

                            <!-- ───────── 每日一言 ───────── -->
                            <TextBlock Text="💬 每日一言" Foreground="#FF8899FF"
                                       FontSize="15" FontWeight="SemiBold"
                                       Margin="6,0,0,12"/>

                            <Border Style="{StaticResource CardPanel}">
                                <StackPanel>
                                    <TextBlock Text="每日一言开关" Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>
                                    <CheckBox Name="ShowDailyQuoteCheck"
                                              Content="在倒计时窗口底部显示每日一言"/>
                                    <TextBlock Text="每日随机展示一条名言/诗词，点击可手动刷新"
                                               FontSize="11" Foreground="#66CCCCDD"
                                               Margin="20,0,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardPanel}">
                                <StackPanel>
                                    <TextBlock Text="显示样式" Style="{StaticResource SectionTitle}" Margin="0,0,0,10"/>
                                    <Grid Margin="0,2,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="字体大小" Foreground="#88CCCCDD"
                                                   FontSize="12" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" x:Name="QuoteFontSizeSlider"
                                                Minimum="8" Maximum="24" TickFrequency="1"
                                                IsSnapToTickEnabled="True"
                                                ValueChanged="QuoteFontSizeSlider_ValueChanged"/>
                                        <TextBlock Grid.Column="2" x:Name="QuoteFontSizeText"
                                                   Foreground="#FFFFFFFF" FontSize="12"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>

                                    <Grid Margin="0,4,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="文字颜色" Foreground="#88CCCCDD"
                                                   FontSize="12" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" x:Name="QuoteForegroundBox"
                                                 Height="28" MaxLength="9"
                                                 Foreground="#CCCCCCDD"
                                                 Background="#15FFFFFF"
                                                 BorderBrush="#20FFFFFF"
                                                 SelectionBrush="#336688CC"/>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="6,0,0,0">
                                            <Rectangle Name="QuoteForegroundPreview"
                                                       Style="{StaticResource ColorPreview}"/>
                                            <Button Content="选择…" Click="SelectQuoteForeground_Click"
                                                    Width="56" FontSize="12" Margin="6,0,0,0"/>
                                        </StackPanel>
                                    </Grid>

                                    <CheckBox Name="QuoteItalicCheck" Content="斜体"
                                              Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardPanel}">
                                <StackPanel>
                                    <TextBlock Text="数据来源" Style="{StaticResource SectionTitle}" Margin="0,0,0,10"/>
                                    <Grid Margin="0,2,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="API 地址" Foreground="#88CCCCDD"
                                                   FontSize="12" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" x:Name="QuoteApiUrlBox"
                                                 Height="28"
                                                 Foreground="#CCCCCCDD"
                                                 Background="#15FFFFFF"
                                                 BorderBrush="#20FFFFFF"
                                                 SelectionBrush="#336688CC"/>
                                    </Grid>
                                    <TextBlock Text="返回格式应为 {&quot;text&quot;: &quot;...&quot;}（与 uapis.cn 兼容）"
                                               FontSize="11" Foreground="#55CCCCDD"
                                               Margin="70,0,0,0" TextWrapping="Wrap"/>

                                    <Grid Margin="0,10,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="文本字段" Foreground="#88CCCCDD"
                                                   FontSize="12" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" x:Name="QuoteTextFieldNameBox"
                                                 Height="28"
                                                 ToolTip="API 返回 JSON 中哪个字段是文本内容，默认 text"
                                                 Foreground="#CCCCCCDD"
                                                 Background="#15FFFFFF"
                                                 BorderBrush="#20FFFFFF"
                                                 SelectionBrush="#336688CC"/>
                                    </Grid>

                                    <Grid Margin="0,10,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="自动切换" Foreground="#88CCCCDD"
                                                   FontSize="12" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" x:Name="QuoteRefreshIntervalSlider"
                                                Minimum="0" Maximum="120" TickFrequency="5"
                                                IsSnapToTickEnabled="True"
                                                ValueChanged="QuoteRefreshIntervalSlider_ValueChanged"/>
                                        <TextBlock Grid.Column="2" x:Name="QuoteRefreshIntervalText"
                                                   Foreground="#FFFFFFFF" FontSize="12"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                    <TextBlock Text="0 = 不自动切换；设置后每隔 N 秒自动刷新一条新的一言"
                                               FontSize="11" Foreground="#55CCCCDD"
                                               Margin="70,0,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- ───────── 分隔线 ───────── -->
                            <Separator Margin="0,14,0,14" Background="#20FFFFFF" Height="1"/>

                            <!-- ───────── 天气 ───────── -->
                            <TextBlock Text="☁ 天气" Foreground="#FF88CCFF"
                                       FontSize="15" FontWeight="SemiBold"
                                       Margin="6,0,0,12"/>

                            <Border Style="{StaticResource CardPanel}">
                                <StackPanel>
                                    <TextBlock Text="城市设置" Style="{StaticResource SectionTitle}" Margin="0,0,0,10"/>
                                    <Grid Margin="0,2,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
