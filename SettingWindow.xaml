                                              Foreground="#DDFFFFFF"
                                              RowBackground="#00FFFFFF"
                                              AlternatingRowBackground="#08FFFFFF"
                                              BorderBrush="#22FFFFFF"
                                              HeadersVisibility="Column"
                                              GridLinesVisibility="Horizontal"
                                              HorizontalGridLinesBrush="#15FFFFFF"
                                              SelectionMode="Single"
                                              SelectionUnit="FullRow"
                                              CanUserResizeRows="False"
                                              EnableRowVirtualization="True">
                                        <DataGrid.Columns>
                                            <DataGridComboBoxColumn Header="星期" Width="65"
                                                SelectedValueBinding="{Binding DayOfWeek}"
                                                SelectedValuePath="Value" DisplayMemberPath="Key">
                                                <DataGridComboBoxColumn.ElementStyle>
                                                    <Style TargetType="ComboBox"
                                                           BasedOn="{StaticResource {x:Type ComboBox}}">
                                                        <Setter Property="FontSize" Value="11"/>
                                                    </Style>
