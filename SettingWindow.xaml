                                                <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Center"/></Style></DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="课程" Width="100" Binding="{Binding Subject}" IsReadOnly="False"/>
                                            <DataGridTextColumn Header="上课" Width="60" Binding="{Binding StartTimeStr}" IsReadOnly="False">
                                                <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Center"/></Style></DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="下课" Width="60" Binding="{Binding EndTimeStr}" IsReadOnly="False">
                                                <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Center"/></Style></DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridComboBoxColumn Header="类型" Width="70"
                                                SelectedValueBinding="{Binding Type}"
                                                SelectedValuePath="Value" DisplayMemberPath="Key">
                                                <DataGridComboBoxColumn.ElementStyle>
                                                    <Style TargetType="ComboBox"
                                                           BasedOn="{StaticResource {x:Type ComboBox}}">
                                                        <Setter Property="FontSize" Value="11"/>
                                                    </Style>
                                                </DataGridComboBoxColumn.ElementStyle>
                                                <DataGridComboBoxColumn.EditingElementStyle>
                                                    <Style TargetType="ComboBox"
                                                           BasedOn="{StaticResource {x:Type ComboBox}}">
                                                        <Setter Property="FontSize" Value="11"/>
                                                    </Style>
                                                </DataGridComboBoxColumn.EditingElementStyle>
                                            </DataGridComboBoxColumn>
                                            <DataGridTextColumn Header="备注" Width="*" Binding="{Binding Remark}" IsReadOnly="False"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <TextBlock x:Name="ScheduleStatusTb" FontSize="12" Foreground="#88CCCCDD"
                                               Margin="0,6,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- ═══ TAB 9：考试模式 ═══ -->
                    <ScrollViewer x:Name="ContentExam" VerticalScrollBarVisibility="Auto" CanContentScroll="False"
                                  Visibility="Collapsed">
                        <StackPanel Margin="6,8,6,12">

                            <!-- 考试模式开关卡片 -->
                            <Border Style="{StaticResource CardPanel}">
                                <StackPanel>
                                    <TextBlock Text="考试模式" Style="{StaticResource SectionTitle}" Margin="0,0,0,10"/>
                                    <CheckBox x:Name="EnableExamModeCheck" Content="启用考试模式（提醒服务检查当天考试）"/>
                                    <CheckBox x:Name="AutoEnterExamModeCheck" Content="当天有考试时，自动进入考试全屏窗口" Margin="0,6,0,0"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                        <Button Content="立即进入考试模式" Click="EnterExamMode_Click" Background="#442D5A3D"/>
                                        <Button Content="退出考试模式" Click="ExitExamMode_Click" Margin="8,0,0,0"/>
                                    </StackPanel>

                                    <TextBlock Text="时间文字大小" Margin="0,18,0,4"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="50"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="字号" Foreground="#88CCCCDD"
                                                   FontSize="12" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" x:Name="ExamModeFontSizeSlider"
                                                Minimum="16" Maximum="60" TickFrequency="1"
                                                IsSnapToTickEnabled="True"
                                                ValueChanged="ExamModeFontSizeSlider_ValueChanged"/>
                                        <TextBlock Grid.Column="2" x:Name="ExamModeFontSizeText"
                                                   Foreground="#FFFFFFFF" FontSize="12"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                    <TextBlock Text="调节考试全屏窗口中当前时间文字的大小"
                                               FontSize="11" Foreground="#66CCCCDD"
                                               Margin="70,0,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- 考试全屏样式卡片 -->
                            <Border Style="{StaticResource CardPanel}">
                                <StackPanel>
                                    <TextBlock Text="全屏样式" Style="{StaticResource SectionTitle}" Margin="0,0,0,10"/>

                                    <!-- 字体大小 -->
                                    <TextBlock Text="字体大小" FontWeight="SemiBold" Margin="0,6,0,4"/>
                                    <!-- 科目名称 -->
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="48"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="科目名称" Foreground="#88CCCCDD" FontSize="12" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" x:Name="ExamSubjectFontSizeSlider"
                                                Minimum="24" Maximum="120" TickFrequency="1"
                                                IsSnapToTickEnabled="True"
                                                ValueChanged="ExamSubjectFontSizeSlider_ValueChanged"/>
                                        <TextBlock Grid.Column="2" x:Name="ExamSubjectFontSizeText"
                                                   Foreground="#FFFFFFFF" FontSize="12"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                    <!-- 考试名称 -->
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="48"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="考试名称" Foreground="#88CCCCDD" FontSize="12" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" x:Name="ExamNameFontSizeSlider"
                                                Minimum="12" Maximum="60" TickFrequency="1"
                                                IsSnapToTickEnabled="True"
                                                ValueChanged="ExamNameFontSizeSlider_ValueChanged"/>
                                        <TextBlock Grid.Column="2" x:Name="ExamNameFontSizeText"
                                                   Foreground="#FFFFFFFF" FontSize="12"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                    <!-- 倒计时 -->
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="48"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="倒计时数字" Foreground="#88CCCCDD" FontSize="12" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" x:Name="ExamCountdownFontSizeSlider"
                                                Minimum="48" Maximum="200" TickFrequency="1"
                                                IsSnapToTickEnabled="True"
                                                ValueChanged="ExamCountdownFontSizeSlider_ValueChanged"/>
                                        <TextBlock Grid.Column="2" x:Name="ExamCountdownFontSizeText"
                                                   Foreground="#FFFFFFFF" FontSize="12"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                    <!-- 时间信息 -->
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="48"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="时间信息" Foreground="#88CCCCDD" FontSize="12" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" x:Name="ExamTimeInfoFontSizeSlider"
                                                Minimum="10" Maximum="36" TickFrequency="1"
                                                IsSnapToTickEnabled="True"
                                                ValueChanged="ExamTimeInfoFontSizeSlider_ValueChanged"/>
                                        <TextBlock Grid.Column="2" x:Name="ExamTimeInfoFontSizeText"
                                                   Foreground="#FFFFFFFF" FontSize="12"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                    <!-- 下一场 -->
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="48"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="下一场" Foreground="#88CCCCDD" FontSize="12" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" x:Name="ExamNextSubjectFontSizeSlider"
                                                Minimum="12" Maximum="48" TickFrequency="1"
                                                IsSnapToTickEnabled="True"
                                                ValueChanged="ExamNextSubjectFontSizeSlider_ValueChanged"/>
                                        <TextBlock Grid.Column="2" x:Name="ExamNextSubjectFontSizeText"
                                                   Foreground="#FFFFFFFF" FontSize="12"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                    <!-- 警告 -->
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="48"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="15分警告" Foreground="#88CCCCDD" FontSize="12" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" x:Name="ExamWarningFontSizeSlider"
                                                Minimum="12" Maximum="48" TickFrequency="1"
                                                IsSnapToTickEnabled="True"
                                                ValueChanged="ExamWarningFontSizeSlider_ValueChanged"/>
                                        <TextBlock Grid.Column="2" x:Name="ExamWarningFontSizeText"
                                                   Foreground="#FFFFFFFF" FontSize="12"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                    <!-- ESC提示 -->
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="48"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="ESC提示" Foreground="#88CCCCDD" FontSize="12" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" x:Name="ExamEscHintFontSizeSlider"
                                                Minimum="8" Maximum="28" TickFrequency="1"
                                                IsSnapToTickEnabled="True"
                                                ValueChanged="ExamEscHintFontSizeSlider_ValueChanged"/>
                                        <TextBlock Grid.Column="2" x:Name="ExamEscHintFontSizeText"
                                                   Foreground="#FFFFFFFF" FontSize="12"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>

                                    <TextBlock Text="颜色" FontWeight="SemiBold" Margin="0,10,0,4"/>
                                    <!-- 科目名颜色 -->
                                    <Grid Margin="0,0,0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="24"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="科目名称" Foreground="#88CCCCDD" FontSize="12" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" x:Name="ExamSubjectColorBox" Width="110"/>
                                        <Rectangle Grid.Column="2" x:Name="ExamSubjectColorPreview"
                                                   Width="18" Height="18" RadiusX="3" RadiusY="3"
                                                   Margin="4,0,0,0" VerticalAlignment="Center"/>
                                    </Grid>
                                    <!-- 考试名颜色 -->
                                    <Grid Margin="0,0,0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="24"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="考试名称" Foreground="#88CCCCDD" FontSize="12" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" x:Name="ExamNameColorBox" Width="110"/>
                                        <Rectangle Grid.Column="2" x:Name="ExamNameColorPreview"
                                                   Width="18" Height="18" RadiusX="3" RadiusY="3"
                                                   Margin="4,0,0,0" VerticalAlignment="Center"/>
                                    </Grid>
                                    <!-- 倒计时正常色 -->
                                    <Grid Margin="0,0,0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="24"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="倒计时(正常)" Foreground="#88CCCCDD" FontSize="12" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" x:Name="ExamCountdownNormalColorBox" Width="110"/>
                                        <Rectangle Grid.Column="2" x:Name="ExamCountdownNormalColorPreview"
                                                   Width="18" Height="18" RadiusX="3" RadiusY="3"
                                                   Margin="4,0,0,0" VerticalAlignment="Center"/>
                                    </Grid>
                                    <!-- 倒计时警告色 -->
                                    <Grid Margin="0,0,0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="24"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="倒计时(警告)" Foreground="#88CCCCDD" FontSize="12" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" x:Name="ExamCountdownWarningColorBox" Width="110"/>
                                        <Rectangle Grid.Column="2" x:Name="ExamCountdownWarningColorPreview"
                                                   Width="18" Height="18" RadiusX="3" RadiusY="3"
                                                   Margin="4,0,0,0" VerticalAlignment="Center"/>
                                    </Grid>
                                    <!-- 倒计时紧迫色 -->
                                    <Grid Margin="0,0,0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="24"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="倒计时(紧迫)" Foreground="#88CCCCDD" FontSize="12" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" x:Name="ExamCountdownCriticalColorBox" Width="110"/>
                                        <Rectangle Grid.Column="2" x:Name="ExamCountdownCriticalColorPreview"
                                                   Width="18" Height="18" RadiusX="3" RadiusY="3"
                                                   Margin="4,0,0,0" VerticalAlignment="Center"/>
                                    </Grid>
                                    <!-- 距开考色 -->
                                    <Grid Margin="0,0,0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="24"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="距开考" Foreground="#88CCCCDD" FontSize="12" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" x:Name="ExamDistanceColorBox" Width="110"/>
                                        <Rectangle Grid.Column="2" x:Name="ExamDistanceColorPreview"
                                                   Width="18" Height="18" RadiusX="3" RadiusY="3"
                                                   Margin="4,0,0,0" VerticalAlignment="Center"/>
                                    </Grid>
                                    <!-- 信息文字色 -->
                                    <Grid Margin="0,0,0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="24"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="信息文字" Foreground="#88CCCCDD" FontSize="12" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" x:Name="ExamInfoColorBox" Width="110"/>
                                        <Rectangle Grid.Column="2" x:Name="ExamInfoColorPreview"
                                                   Width="18" Height="18" RadiusX="3" RadiusY="3"
                                                   Margin="4,0,0,0" VerticalAlignment="Center"/>
                                    </Grid>
                                    <!-- 进度条颜色 -->
                                    <Grid Margin="0,0,0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="24"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="进度条" Foreground="#88CCCCDD" FontSize="12" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" x:Name="ExamProgressBarColorBox" Width="110"/>
                                        <Rectangle Grid.Column="2" x:Name="ExamProgressBarColorPreview"
                                                   Width="18" Height="18" RadiusX="3" RadiusY="3"
                                                   Margin="4,0,0,0" VerticalAlignment="Center"/>
                                    </Grid>

                                    <TextBlock Text="进度条高度" FontWeight="SemiBold" Margin="0,12,0,4"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="48"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="高度" Foreground="#88CCCCDD" FontSize="12" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" x:Name="ExamProgressBarHeightSlider"
                                                Minimum="4" Maximum="40" TickFrequency="1"
                                                IsSnapToTickEnabled="True"
                                                ValueChanged="ExamProgressBarHeightSlider_ValueChanged"/>
                                        <TextBlock Grid.Column="2" x:Name="ExamProgressBarHeightText"
                                                   Foreground="#FFFFFFFF" FontSize="12"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                    <TextBlock Text="调节考试全屏窗口中进度条的粗细"
                                               FontSize="11" Foreground="#66CCCCDD"
                                               Margin="90,0,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- 考试列表编辑卡片 -->
                            <Border Style="{StaticResource CardPanel}">
                                <StackPanel>
                                    <TextBlock Text="考试列表" Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <Button Content="＋ 添加考试" Click="AddExam_Click"
                                                Width="100" Background="#332D5A3D"/>
                                        <Button Content="－ 删除考试" Click="DeleteExam_Click"
                                                Width="90" Margin="6,0,0,0" Background="#33552222"/>
                                    </StackPanel>
                                    <DataGrid x:Name="ExamDataGrid"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              RowHeight="28"
                                              MaxHeight="180"
                                              Background="#11FFFFFF"
                                              Foreground="#DDFFFFFF"
                                              RowBackground="#00FFFFFF"
                                              AlternatingRowBackground="#08FFFFFF"
                                              BorderBrush="#22FFFFFF"
                                              HeadersVisibility="Column"
                                              GridLinesVisibility="Horizontal"
                                              HorizontalGridLinesBrush="#15FFFFFF"
                                              SelectionMode="Single"
                                              SelectionUnit="FullRow"
                                              CanUserResizeRows="False"
                                              SelectionChanged="ExamDataGrid_SelectionChanged">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="考试名称" Width="180" Binding="{Binding Name}" IsReadOnly="False"/>
                                            <DataGridTextColumn Header="日期" Width="120" Binding="{Binding DateStr}" IsReadOnly="False">
                                                <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Center"/></Style></DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="科目数" Width="*" Binding="{Binding Subjects.Count}" IsReadOnly="True">
                                                <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Center"/></Style></DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <TextBlock Text="选中考试后编辑其科目：" FontSize="12" Foreground="#88CCCCDD" Margin="0,10,0,4"/>
                                </StackPanel>
                            </Border>

                            <!-- 科目编辑卡片（联动选中考试） -->
                            <Border Style="{StaticResource CardPanel}">
                                <StackPanel>
                                    <TextBlock Text="科目列表" Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <Button Content="＋ 添加科目" Click="AddExamSubject_Click"
                                                Width="100" Background="#332D5A3D"/>
                                        <Button Content="－ 删除科目" Click="DeleteExamSubject_Click"
                                                Width="90" Margin="6,0,0,0" Background="#33552222"/>
                                    </StackPanel>
                                    <DataGrid x:Name="ExamSubjectGrid"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              RowHeight="28"
                                              MaxHeight="180"
                                              Background="#11FFFFFF"
                                              Foreground="#DDFFFFFF"
                                              RowBackground="#00FFFFFF"
                                              AlternatingRowBackground="#08FFFFFF"
                                              BorderBrush="#22FFFFFF"
                                              HeadersVisibility="Column"
                                              GridLinesVisibility="Horizontal"
                                              HorizontalGridLinesBrush="#15FFFFFF"
                                              SelectionMode="Single"
                                              SelectionUnit="FullRow"
                                              CanUserResizeRows="False">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="科目名称" Width="140" Binding="{Binding Name}" IsReadOnly="False"/>
                                            <DataGridTextColumn Header="开考时间" Width="90" Binding="{Binding StartTimeStr}" IsReadOnly="False">
                                                <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Center"/></Style></DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="结束时间" Width="90" Binding="{Binding EndTimeStr}" IsReadOnly="False">
                                                <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Center"/></Style></DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="时长" Width="*" Binding="{Binding Duration}" IsReadOnly="True">
                                                <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Center"/></Style></DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <Button Content="保存考试数据" Click="SaveExams_Click" Width="110"/>
                                        <Button Content="从 JSON 导入" Click="ImportExamJson_Click" Width="100" Margin="6,0,0,0"/>
                                    </StackPanel>
                                    <TextBlock x:Name="ExamStatusTb" FontSize="12" Foreground="#88CCCCDD"
                                               Margin="0,6,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>

                </Grid>
            </Grid>

            <!-- ══════ 底部按钮栏 ══════ -->
            <Border Grid.Row="2" Background="#08FFFFFF" CornerRadius="0,0,14,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            Margin="0,0,12,0" VerticalAlignment="Center">
                    <Button Content="重置默认" Click="ResetButton_Click" Width="76"
                            Background="#22FF6666" Foreground="#FFFF8888"/>
                    <Button Content="应用"   Click="ApplyButton_Click"  Width="64"/>
                    <Button Content="确定"   Click="OKButton_Click"     Width="64"
                            Background="#336688CC"/>
                    <Button Content="取消"   Click="CancelButton_Click" Width="64"
                            Background="#22FFFFFF"/>
                </StackPanel>
            </Border>

        </Grid>
    </Grid>
</Window>

