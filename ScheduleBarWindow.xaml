<Window x:Class="GaokaoCountdown.ScheduleBarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="课表栏"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Window.Resources>
        <!-- 课节卡片基础样式 -->
        <Style x:Key="PeriodCard" TargetType="Border">
            <Setter Property="Background" Value="#CC1A1A2E"/>
            <Setter Property="BorderBrush" Value="#44FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="MinWidth" Value="90"/>
        </Style>
        <!-- 当前课节高亮样式 -->
        <Style x:Key="PeriodCardActive" TargetType="Border" BasedOn="{StaticResource PeriodCard}">
            <Setter Property="Background" Value="#CC2D5A3D"/>
            <Setter Property="BorderBrush" Value="#FF4CAF50"/>
            <Setter Property="BorderThickness" Value="1.5"/>
        </Style>
        <!-- 下一节课样式 -->
        <Style x:Key="PeriodCardNext" TargetType="Border" BasedOn="{StaticResource PeriodCard}">
            <Setter Property="Background" Value="#CC2A3A5E"/>
            <Setter Property="BorderBrush" Value="#FF5B9BD5"/>
            <Setter Property="BorderThickness" Value="1.5"/>
        </Style>
    </Window.Resources>

    <!-- 外层容器，整体控制圆角与背景 -->
    <Border Background="#DD0D0D1A" CornerRadius="0,0,6,6" Padding="0,2,0,2">
        <Grid>
            <!-- ── 紧凑模式行（上课时仅显示进度条）── -->
            <Grid x:Name="CompactRow" Visibility="Collapsed" Margin="6,2"
                  Panel.ZIndex="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" x:Name="CompactSubjectTb"
                           FontSize="11" FontWeight="Bold" Foreground="#CCFFFFFF"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>

                <Grid Grid.Column="1">
                    <ProgressBar x:Name="CompactProgress" Height="8"
                                 Background="#22FFFFFF" Foreground="#FF4CAF50"
                                 Minimum="0" Maximum="100"/>
                    <TextBlock x:Name="CompactPctTb" FontSize="10" FontWeight="SemiBold"
                               Foreground="#FFFFFFFF"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>

                <TextBlock Grid.Column="2" x:Name="CompactRemainingTb"
                           FontSize="10" Foreground="#88CCFF"
                           VerticalAlignment="Center" Margin="8,0,0,0"/>
            </Grid>

            <!-- ── 完整信息行（含主区域 + 进度条，作为一个整体显隐）── -->
            <StackPanel x:Name="FullInfoRoot" Panel.ZIndex="0">
                <!-- 主信息 -->
                <Grid Margin="6,1,6,1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左：当前时间 + 日期 -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0">
                        <TextBlock x:Name="CurrentTimeTb"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="#FFFFFFFF"
                                   FontFamily="Consolas"/>
                        <TextBlock x:Name="DateTb"
                                   FontSize="9" Foreground="#AAFFFFFF"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- 中：课节滚动列表 -->
                    <ScrollViewer Grid.Column="1"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  Background="Transparent">
                        <StackPanel x:Name="PeriodPanel" Orientation="Horizontal"
                                    VerticalAlignment="Center" Margin="0,2"/>
                    </ScrollViewer>

                    <!-- 右：状态信息面板 -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="8,0,0,0"
                                MinWidth="110">
                        <TextBlock x:Name="StatusTb"
                                   FontSize="9" Foreground="#AAFFFFFF"
                                   HorizontalAlignment="Right"/>
                        <TextBlock x:Name="NextCountdownTb"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="#FFFF8844"
                                   HorizontalAlignment="Right"/>
                        <Border x:Name="Countdown60Panel" Visibility="Collapsed"
                                Background="#881A0000" CornerRadius="3" Padding="4,1" Margin="0,1,0,0">
                            <TextBlock x:Name="Countdown60Tb"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="#FFFF4444"
                                       HorizontalAlignment="Center"/>
                        </Border>
                    </StackPanel>

                    <!-- 最右：天气 -->
                    <StackPanel Grid.Column="3" x:Name="WeatherRow" Visibility="Collapsed"
                                VerticalAlignment="Center" Margin="10,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="WeatherIconTb" FontSize="12"
                                       VerticalAlignment="Center" Margin="0,0,3,0"/>
                            <TextBlock x:Name="WeatherTempTb" FontSize="11" FontWeight="Bold"
                                       Foreground="#FF88CCFF" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="WeatherCityTb" FontSize="9"
                                   Foreground="#88FFFFFF" Margin="0,1,0,0"/>
                        <TextBlock x:Name="WeatherTb" FontSize="9"
                                   Foreground="#88FFFFFF"/>
                        <TextBlock x:Name="WeatherWindTb" FontSize="8"
                                   Foreground="#66FFFFFF" Visibility="Collapsed"/>
                        <TextBlock x:Name="WeatherHumidityTb" FontSize="8"
                                   Foreground="#66FFFFFF" Visibility="Collapsed"/>
                    </StackPanel>
                </Grid>

                <!-- 当前课进度条（位于完整模式底部） -->
                <Grid Margin="6,0,6,2" x:Name="ProgressRow" Visibility="Collapsed">
                    <ProgressBar x:Name="CurrentClassProgress" Height="6"
                                 Background="#33FFFFFF" Foreground="#FF4CAF50"
                                 Minimum="0" Maximum="100"/>
                    <Grid Margin="8,0">
                        <TextBlock x:Name="ProgressLabelTb"
                                   FontSize="9" Foreground="#CCFFFFFF"
                                   HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <TextBlock x:Name="ProgressPctTb"
                                   FontSize="9" Foreground="#FFFFFFFF"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</Window>
